# 环境变量配置示例
# 复制此文件为 .env: cp .env.example .env

# ==============================
# 核心配置（所有环境必需）
# ==============================
# NEXTAUTH_SECRET 可以使用 openssl rand -base64 32 命令生成
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ==============================
# Docker 部署 - PostgreSQL（默认）
# ==============================
# 使用 docker-compose.yml 启动（PostgreSQL + 应用）
# DATABASE_URL 会自动生成，无需手动配置
POSTGRES_USER=nav
POSTGRES_PASSWORD=FkyM5NhrsYHtmmKc
POSTGRES_DB=nav
POSTGRES_PORT=5432
PORT=3000

# ==============================
# Docker 部署 - SQLite（轻量级）
# ==============================
# 使用 docker-compose.sqlite.yml 启动（仅应用，使用 SQLite）
# 启动命令: docker compose -f docker-compose.sqlite.yml up -d
# DATABASE_URL=file:/app/data/nav.db  # 已在 compose 文件中配置
## 注意：Docker 默认构建的是 PostgreSQL 版本镜像（PRISMA_PROVIDER=postgresql）。
## SQLite 版本需要使用 docker-compose.sqlite.yml（会用 PRISMA_PROVIDER=sqlite 构建）。

# ==============================
# 本地开发（不使用 Docker）
# ==============================
# 必须配置 DATABASE_URL
# SQLite（推荐用于本地开发）:
# DATABASE_URL=file:./dev.db

# PostgreSQL（需要本地安装 PostgreSQL）:
# DATABASE_URL=postgresql://nav:password@localhost:5432/nav
