# 环境变量配置示例
# 复制此文件为 .env: cp .env.example .env

# ==============================
# 核心配置（所有环境必需）
# ==============================
# NEXTAUTH_SECRET 可以使用 openssl rand -base64 32 命令生成
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# ==============================
# Docker 部署 - PostgreSQL（默认）
# ==============================
# 使用 docker-compose.yml 启动（PostgreSQL + 远程镜像）
# 会直接拉取 ghcr.io/690788955/nav:latest，不使用本地 SQLite schema 构建
# DATABASE_URL 会自动生成，无需手动配置
POSTGRES_USER=nav
POSTGRES_PASSWORD=FkyM5NhrsYHtmmKc
POSTGRES_DB=nav
POSTGRES_PORT=5432
PORT=3000

# ==============================
# 本地开发（不使用 Docker）
# ==============================
# 本地开发固定使用 SQLite（推荐）
# DATABASE_URL=file:./dev.db
